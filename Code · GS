const SHEET_ID = '填入你的試算表ID'; // ← 務必修改這裡 [cite: 1, 2]
const SHEET_REG = '活動報名'; 

function doGet(e) {
  const type = e.parameter?.type;
  if (type === "count") {
    const ss = SpreadsheetApp.openById(SHEET_ID);
    const sheet = ss.getSheetByName(SHEET_REG);
    const count = sheet ? Math.max(0, sheet.getLastRow() - 1) : 0;
    return ContentService.createTextOutput(JSON.stringify({ count }))
      .setMimeType(ContentService.MimeType.JSON);
  }
  return HtmlService.createTemplateFromFile('index')
    .evaluate()
    .setTitle('統一企業參訪活動專用')
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

