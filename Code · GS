function submitOrder(formData) {
  try {
    const ss = SpreadsheetApp.openById(SHEET_ID);
    let sheet = ss.getSheetByName('訂單記錄') || ss.insertSheet('訂單記錄');
    if (sheet.getLastRow() === 0) {
      sheet.appendRow(['提交時間', '參訪日期', '姓名', '單位', '品項', '溫度', '冰塊', '備註']);
    }
    sheet.appendRow([new Date(), formData.visitDate, formData.name, formData.department, formData.itemName, formData.temperature, formData.iceLevel, formData.notes]);
    return { success: true };
  } catch (e) { return { success: false, message: e.message }; }
}
